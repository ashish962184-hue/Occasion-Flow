{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "server.js"
    }
  },
  "functions": {
    "backend/server.js": {
      "includeFiles": "backend/database/database.sqlite"
    },
    "server.js": {
      "includeFiles": "database/database.sqlite"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/_/backend/api/$1"
    },
    {
      "source": "/((?!api/|assets/|_/backend/|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
